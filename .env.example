VITE_SUPABASE_URL=your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

VITE_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# URL pública de la PWA (para success/cancel de Stripe y el rebote nativo).
# Si se omite, en web cae a window.location.origin.
VITE_APP_URL=https://ourtime.app

# Activa el paywall/gates de monetización. Deja en 'false' para desplegar la
# infra de pagos sin cobrar todavía.
VITE_PAYWALL_ENABLED=false

# Supabase Edge Function secrets (set with `supabase secrets set`, not exposed to Vite)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
