# Web Push (the public key must match VITE_VAPID_PUBLIC_KEY in the frontend)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Firebase service account JSON for Android FCM HTTP v1
FCM_SERVICE_ACCOUNT=

# Google OAuth credentials used to renew Calendar access tokens
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (monetización). Usa claves de test (sk_test_… / whsec_…) en desarrollo.
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase functions deploy stripe-webhook --no-verify-jwt   (webhook NO valida JWT)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# price_id de cada plan/intervalo (los creas en el Dashboard de Stripe)
STRIPE_PRICE_DUO_MONTHLY=
STRIPE_PRICE_DUO_YEARLY=
STRIPE_PRICE_FAMILIA_MONTHLY=
